# ── Preferred: OpenRouter (OpenAI-compatible gateway) ──────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Alternatives (used only if OPENROUTER_API_KEY is unset) ────────
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default model
# LLM_MODEL=gemini-2.5-flash

# Optional: real HITL interrupts (default: mock approval)
# LANGGRAPH_INTERRUPT=true

# Optional: persistence backend
CHECKPOINTER=memory
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/langgraph_lab

LOG_LEVEL=INFO
